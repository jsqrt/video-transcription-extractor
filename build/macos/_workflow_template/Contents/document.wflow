				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>Run Shell Script</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>APP="/Applications/Describely.app"
if [ ! -d "$APP" ]; then
  osascript -e 'display alert "Describely not found" message "Install it into /Applications first."'
  exit 1
fi
# `open -n -a APP --args ...` ALWAYS launches a fresh process and passes
# the rest as argv. The `-n` is essential: a plain `open -a` would merely
# re-activate an already-running Describely and silently drop --args, so
# the file never reached the open window. The fresh process parses --mode
# + files (via _expand_args in __main__.py) and, if a primary instance is
# already running, hands them over via single-instance IPC and exits.
open -n -a "$APP" --args --mode __MODE__ "$@"
</string>
